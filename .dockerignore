__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
venv/
env/
.env

# Distribution / packaging
build/
dist/
*.egg-info/

# Logs
logs/
*.log

# Editor directories and files
.vscode/
.idea/
*.swp
